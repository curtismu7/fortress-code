{
  "name": "fortress-chat",
  "displayName": "FortressChat",
  "description": "Local US-model chat + agent for VS Code. Memory-safe llama.cpp management built in.",
  "version": "0.1.11",
  "publisher": "coachcurtis",
  "repository": {
    "type": "git",
    "url": "https://github.com/curtismu7/fortress-chat"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "FortressChat",
      "properties": {
        "fortressChat.mcpServers": {
          "type": "array",
          "default": [],
          "description": "MCP stdio servers for agent mode. Tools are available when Agent mode is on.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Short label shown in the chat UI"
              },
              "command": {
                "type": "string",
                "description": "Executable (e.g. npx, node, uv)"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command arguments"
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Extra environment variables for the server process"
              }
            },
            "required": [
              "name",
              "command"
            ]
          }
        },
        "fortressChat.skillDirectories": {
          "type": "array",
          "default": [
            "~/.cursor/skills-cursor",
            "~/.claude/skills",
            "~/.codex/skills",
            ".fortress/skills"
          ],
          "description": "Directories to scan recursively for SKILL.md files (supports ~ and workspace-relative paths).",
          "items": {
            "type": "string"
          }
        },
        "fortressChat.modelsDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom folder for local GGUF models. Each catalog model expects a subfolder (e.g. gemma-3-4b-qat/). Empty uses ~/Library/Application Support/fortress-chat/models."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fortress-chat",
          "title": "FortressChat",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "fortress-chat": [
        {
          "type": "webview",
          "id": "fortressChat.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "fortress-chat.openChatInEditor",
        "title": "FortressChat: Open Chat in Editor Tab"
      },
      {
        "command": "fortress-chat.openChat",
        "title": "FortressChat: Open Chat"
      },
      {
        "command": "fortress-chat.reloadWebview",
        "title": "FortressChat: Reload Chat Webview"
      },
      {
        "command": "fortress-chat.reloadMcp",
        "title": "FortressChat: Reload MCP Servers"
      },
      {
        "command": "fortress-chat.reloadSkills",
        "title": "FortressChat: Reload Skills"
      },
      {
        "command": "fortress-chat.toggleDevMode",
        "title": "FortressChat: Toggle Developer Mode"
      },
      {
        "command": "fortress-chat.explainSelection",
        "title": "FortressChat: Explain Selection"
      },
      {
        "command": "fortress-chat.fixSelection",
        "title": "FortressChat: Fix Selection"
      },
      {
        "command": "fortress-chat.testSelection",
        "title": "FortressChat: Add Tests Selection"
      },
      {
        "command": "fortress-chat.refactorSelection",
        "title": "FortressChat: Refactor Selection"
      },
      {
        "command": "fortress-chat.docSelection",
        "title": "FortressChat: Document Selection"
      },
      {
        "command": "fortress-chat.inlineEdit",
        "title": "FortressChat: Inline Edit"
      }
    ],
    "keybindings": [
      {
        "command": "fortress-chat.toggleDevMode",
        "key": "ctrl+alt+m",
        "mac": "ctrl+alt+m"
      },
      {
        "command": "fortress-chat.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "submenus": [
      {
        "id": "fortress-chat.selection",
        "label": "FortressChat"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "fortress-chat.selection",
          "group": "1_modification",
          "when": "editorHasSelection"
        }
      ],
      "fortress-chat.selection": [
        {
          "command": "fortress-chat.explainSelection",
          "group": "1@1"
        },
        {
          "command": "fortress-chat.fixSelection",
          "group": "1@2"
        },
        {
          "command": "fortress-chat.testSelection",
          "group": "1@3"
        },
        {
          "command": "fortress-chat.refactorSelection",
          "group": "1@4"
        },
        {
          "command": "fortress-chat.docSelection",
          "group": "1@5"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run build -w @fortress-chat/shared && node esbuild.mjs && tsc -p tsconfig.json --noEmit",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:e2e": "npm run build && node out/test/e2e/runTest.js",
    "package": "npx --yes @vscode/vsce package --no-dependencies -o ../../fortress-chat.vsix",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@fortress-chat/shared": "0.1.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.12",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
