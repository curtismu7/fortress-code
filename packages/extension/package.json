{
  "name": "fortress-code",
  "displayName": "Fortress Code",
  "description": "Local US-model chat + agent for VS Code. Memory-safe llama.cpp management built in.",
  "version": "0.1.7",
  "publisher": "coachcurtis",
  "repository": {
    "type": "git",
    "url": "https://github.com/curtismu7/fortress-code"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "Fortress Code",
      "properties": {
        "fortressCode.mcpServers": {
          "type": "array",
          "default": [],
          "description": "MCP stdio servers for agent mode (name, command, args).",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["name", "command"]
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fortress-code",
          "title": "Fortress Code",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "fortress-code": [
        {
          "type": "webview",
          "id": "fortressCode.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "fortress-code.openChat",
        "title": "Fortress Code: Open Chat"
      },
      {
        "command": "fortress-code.toggleDevMode",
        "title": "Fortress Code: Toggle Developer Mode"
      },
      {
        "command": "fortress-code.explainSelection",
        "title": "Fortress Code: Explain Selection"
      },
      {
        "command": "fortress-code.fixSelection",
        "title": "Fortress Code: Fix Selection"
      },
      {
        "command": "fortress-code.testSelection",
        "title": "Fortress Code: Add Tests Selection"
      },
      {
        "command": "fortress-code.refactorSelection",
        "title": "Fortress Code: Refactor Selection"
      },
      {
        "command": "fortress-code.docSelection",
        "title": "Fortress Code: Document Selection"
      },
      {
        "command": "fortress-code.inlineEdit",
        "title": "Fortress Code: Inline Edit"
      }
    ],
    "keybindings": [
      {
        "command": "fortress-code.toggleDevMode",
        "key": "ctrl+alt+m",
        "mac": "ctrl+alt+m"
      },
      {
        "command": "fortress-code.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "submenus": [
      {
        "id": "fortress-code.selection",
        "label": "Fortress Code"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "fortress-code.selection",
          "group": "1_modification",
          "when": "editorHasSelection"
        }
      ],
      "fortress-code.selection": [
        {
          "command": "fortress-code.explainSelection",
          "group": "1@1"
        },
        {
          "command": "fortress-code.fixSelection",
          "group": "1@2"
        },
        {
          "command": "fortress-code.testSelection",
          "group": "1@3"
        },
        {
          "command": "fortress-code.refactorSelection",
          "group": "1@4"
        },
        {
          "command": "fortress-code.docSelection",
          "group": "1@5"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "package": "npx --yes @vscode/vsce package --no-dependencies -o ../../fortress-code.vsix",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@fortress-code/shared": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.12",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
