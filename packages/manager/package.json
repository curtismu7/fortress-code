{
  "name": "@fortress-chat/manager",
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "brave:mcp": "node dist/braveMcpWrapper.js",
    "brave:mcp:cloud": "BRAVE_WRAPPER_HOST=0.0.0.0 BRAVE_WRAPPER_PORT=${PORT:-8080} node dist/braveMcpWrapper.js",
    "brave:mcp:dev": "npm run build && npm run brave:mcp",
    "brave:token": "node dist/mintBraveToken.js",
    "brave:token:dev": "npm run build && npm run brave:token",
    "test": "vitest run"
  },
  "dependencies": {
    "@fortress-chat/shared": "0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
